PORT=3000
NODE_ENV=development

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2-chat-latest
OPENAI_INTERPRETER_MODEL=gpt-5.2
OPENAI_TIMEOUT_MS=7000
OPENAI_TRANSCRIPTION_MODEL=whisper-1
AI_INTERPRETER=true
HUMANIZAR_IA=true
MEDIA_DOWNLOAD_TIMEOUT_MS=10000
MEDIA_MAX_BYTES=25165824
INBOUND_MESSAGE_BUFFER_MS=2000

# Kapso sandbox
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=
KAPSO_WEBHOOK_SECRET=
KAPSO_API_BASE_URL=https://api.kapso.ai
META_GRAPH_VERSION=v24.0

# Supabase backend only
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Alternative accepted by the code:
# SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_CONVERSATIONS_TABLE=whatsapp_conversations
SUPABASE_MESSAGES_TABLE=whatsapp_messages
SUPABASE_ORDERS_TABLE=whatsapp_orders
SUPABASE_TRAINING_EXAMPLES_TABLE=training_examples
